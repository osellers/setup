#!/usr/bin/env bash
# tmux-dev [path]
#
# Create (or re-attach to) a tmux dev session for a repo. A single window is
# split into three panes:
#
#   +----------+--------------+
#   |          |    claude    |   left  = nvim .   (45% width)
#   |   nvim   +--------------+   t-rgt = claude    (60% of right column)
#   |          |  terminal    |   b-rgt = plain fish shell (40%)
#   +----------+--------------+
#
# The session is named after the repo directory, so running the command again
# (e.g. after an SSH reconnect) re-attaches to the same session instead of
# making a new one. Works whether or not you're already inside tmux.
#
# Usage:
#   tmux-dev               # use the current directory
#   tmux-dev ~/code/foo    # use a specific repo
set -euo pipefail

dir="${1:-$PWD}"
if [ ! -d "$dir" ]; then
  echo "tmux-dev: not a directory: $dir" >&2
  exit 1
fi
dir="$(cd "$dir" && pwd)"

# tmux session names can't contain '.' or ':'; sanitize the repo basename.
name="$(basename "$dir" | tr ' .:' '___')"

if ! tmux has-session -t "=$name" 2>/dev/null; then
  # Left pane (0): nvim
  tmux new-session -d -s "$name" -c "$dir" -n dev
  tmux send-keys   -t "$name:dev.0" 'nvim .' C-m
  # Right column (1): take 55% width so the left (nvim) pane stays smaller,
  # run claude on top
  tmux split-window -h -l 55% -t "$name:dev.0" -c "$dir"
  tmux send-keys    -t "$name:dev.1" 'claude' C-m
  # Bottom-right (2): give it 40% so the top (claude) pane is bigger
  tmux split-window -v -l 40% -t "$name:dev.1" -c "$dir"
  # Start focused on nvim
  tmux select-pane  -t "$name:dev.0"
fi

if [ -n "${TMUX:-}" ]; then
  tmux switch-client -t "$name"
else
  tmux attach-session -t "$name"
fi
